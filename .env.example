# .env.example — copy this file to .env and fill in your credentials
# The .env file is gitignored — never commit real credentials.
#
# Load in shell:  source .env   OR   use python-dotenv in your code.

# ── Email alerts ──────────────────────────────────────────────────────────────
# Set SIGNAL_EMAIL_ENABLED=true to activate alerts.
# Gmail setup: myaccount.google.com → Security → App Passwords → Generate
SIGNAL_EMAIL_ENABLED=false
SIGNAL_EMAIL_SENDER=you@gmail.com
SIGNAL_EMAIL_PASSWORD=abcd efgh ijkl mnop   # 16-char Gmail App Password
SIGNAL_EMAIL_RECIPIENT=recipient@gmail.com
SIGNAL_SMTP_HOST=smtp.gmail.com
SIGNAL_SMTP_PORT=587

# ── Reddit API ─────────────────────────────────────────────────────────────────
# Register at https://www.reddit.com/prefs/apps → create "script" app
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Time (local) to run the daily pipeline
SIGNAL_SCHEDULE_HOUR=8
SIGNAL_SCHEDULE_MINUTE=0
